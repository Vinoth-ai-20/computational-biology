    "## 2. Visualization"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import matplotlib.pyplot as plt\n",
    "import matplotlib.patches as mpatches\n",
    "import numpy as np\n",
    "\n",
    "fig, axes = plt.subplots(1, 2, figsize=(14, 6))\n",
    "fig.suptitle('Test Suite Results', fontsize=14, fontweight='bold')\n",
    "\n",
    "# --- Panel 1: Test result matrix ---\n",
    "ax1 = axes[0]\n",
    "ax1.set_title('Parametrized Test Matrix', fontweight='bold')\n",
    "\n",
    "fn_labels = [r[0] for r in results]\n",
    "test_ids   = [r[1] for r in results]\n",
    "pass_fail  = [1 if r[5] else 0 for r in results]\n",
    "\n",
    "# Build a grid: functions on Y, test cases as row bars\n",
    "colors_tf = ['#2ecc71' if v else '#e74c3c' for v in pass_fail]\n",
    "y_pos = range(len(results))\n",
    "bars = ax1.barh(y_pos, [1]*len(results), color=colors_tf, alpha=0.8, height=0.6)\n",
    "\n",
    "labels_full = [f'{r[0]}: {r[2]!r}' for r in results]\n",
    "ax1.set_yticks(list(y_pos))\n",
    "ax1.set_yticklabels(labels_full, fontsize=7, fontfamily='monospace')\n",
    "ax1.set_xticks([])\n",
    "ax1.set_xlabel('PASS / FAIL')\n",
    "ax1.invert_yaxis()\n",
    "\n",
    "for i, (bar, ok) in enumerate(zip(bars, pass_fail)):\n",
    "    ax1.text(0.5, i, 'PASS' if ok else 'FAIL', va='center', ha='center',\n",
    "             fontsize=8, color='white', fontweight='bold')\n",
    "\n",
    "pass_patch = mpatches.Patch(color='#2ecc71', label='PASS')\n",
    "fail_patch = mpatches.Patch(color='#e74c3c', label='FAIL')\n",
    "ax1.legend(handles=[pass_patch, fail_patch], loc='lower right')\n",
    "\n",
    "# --- Panel 2: Coverage pie chart (simulated) ---\n",
    "ax2 = axes[1]\n",
    "ax2.set_title('Coverage Report (simulated)', fontweight='bold')\n",
    "\n",
    "modules = ['sequence.py\\nreverse_complement', 'sequence.py\\ngc_content',\n",
    "           'stats.py\\n(skeleton)', 'io.py\\n(skeleton)']\n",
    "covered = [100, 100, 0, 0]  # skeletons have 0% coverage until NB08-10\n",
    "not_covered = [100 - c for c in covered]\n",
    "\n",
    "x = np.arange(len(modules))\n",
    "width = 0.35\n",
    "ax2.bar(x, covered, width, label='Covered', color='#2ecc71', alpha=0.8)\n",
    "ax2.bar(x, not_covered, width, bottom=covered, label='Not covered', color='#e74c3c', alpha=0.8)\n",
    "\n",
    "ax2.set_ylabel('Coverage (%)')\n",
    "ax2.set_xticks(x)\n",
    "ax2.set_xticklabels(modules, fontsize=8)\n",
    "ax2.set_ylim(0, 130)\n",
    "ax2.legend()\n",
    "ax2.axhline(y=80, color='orange', linestyle='--', label='80% threshold')\n",
    "ax2.text(len(modules) - 0.5, 82, '80% threshold', color='orange', fontsize=8)\n",
    "\n",
    "for i, c in enumerate(covered):\n",
    "    ax2.text(i, c + 2, f'{c}%', ha='center', fontsize=9, fontweight='bold')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('testing_overview.png', dpi=120, bbox_inches='tight')\n",
    "plt.show()"
   ]
