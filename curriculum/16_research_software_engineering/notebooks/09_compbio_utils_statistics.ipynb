   "source": [
    "## Visualization"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import matplotlib.pyplot as plt\n",
    "import numpy as np\n",
    "\n",
    "rng = np.random.default_rng(42)\n",
    "fig, axes = plt.subplots(1, 3, figsize=(15, 5))\n",
    "fig.suptitle('compbio_utils.stats — Visualizations', fontsize=13, fontweight='bold')\n",
    "\n",
    "# --- Panel 1: Bootstrap distribution + CI ---\n",
    "ax1 = axes[0]\n",
    "data = rng.normal(loc=0.5, scale=0.1, size=50)\n",
    "boot_stats = np.array([\n",
    "    np.mean(rng.choice(data, size=len(data), replace=True))\n",
    "    for _ in range(5000)\n",
    "])\n",
    "lo_ci = np.percentile(boot_stats, 2.5)\n",
    "hi_ci = np.percentile(boot_stats, 97.5)\n",
    "\n",
    "ax1.hist(boot_stats, bins=50, color='#3498db', alpha=0.7, edgecolor='white')\n",
    "ax1.axvline(np.mean(data), color='#e74c3c', lw=2, label=f'Observed mean: {np.mean(data):.3f}')\n",
    "ax1.axvline(lo_ci, color='#27ae60', lw=2, linestyle='--', label=f'95% CI: [{lo_ci:.3f}, {hi_ci:.3f}]')\n",
    "ax1.axvline(hi_ci, color='#27ae60', lw=2, linestyle='--')\n",
    "ax1.fill_betweenx([0, ax1.get_ylim()[1] if ax1.get_ylim()[1] > 0 else 500],\n",
    "                  lo_ci, hi_ci, alpha=0.15, color='#27ae60')\n",
    "ax1.set_xlabel('Bootstrap mean')\n",
    "ax1.set_ylabel('Count')\n",
    "ax1.set_title('Bootstrap CI (n_boot=5000)', fontweight='bold')\n",
    "ax1.legend(fontsize=8)\n",
    "\n",
    "# --- Panel 2: Volcano plot (log2FC vs -log10 p-value) ---\n",
    "ax2 = axes[1]\n",
    "n_genes = 200\n",
    "lfc_all = rng.normal(0, 1, n_genes)\n",
    "pvals_all = rng.uniform(0, 1, n_genes)\n",
    "# Make some genes \"significant\" by design\n",
    "sig_idx = rng.choice(n_genes, 20, replace=False)\n",
    "lfc_all[sig_idx] = rng.choice([-1, 1], 20) * rng.uniform(2, 4, 20)\n",
    "pvals_all[sig_idx] = rng.uniform(0, 0.001, 20)\n",
    "\n",
    "qvals_all = multiple_testing_correction(pvals_all, method='fdr_bh')\n",
    "neg_log10_p = -np.log10(pvals_all + 1e-300)\n",
    "\n",
    "sig_mask = (qvals_all < 0.05) & (np.abs(lfc_all) > 1)\n",
    "ax2.scatter(lfc_all[~sig_mask], neg_log10_p[~sig_mask],\n",
    "            color='#bdc3c7', alpha=0.6, s=20, label='Not significant')\n",
    "ax2.scatter(lfc_all[sig_mask], neg_log10_p[sig_mask],\n",
    "            color='#e74c3c', alpha=0.9, s=40, label='Significant (q<0.05, |LFC|>1)')\n",
    "ax2.axhline(-np.log10(0.05), color='orange', linestyle='--', alpha=0.7, label='p=0.05')\n",
    "ax2.axvline(-1, color='#3498db', linestyle='--', alpha=0.7)\n",
    "ax2.axvline(1, color='#3498db', linestyle='--', alpha=0.7, label='|LFC|=1')\n",
    "ax2.set_xlabel('log2 Fold Change')\n",
    "ax2.set_ylabel('-log10(p-value)')\n",
    "ax2.set_title('Volcano Plot (200 simulated genes)', fontweight='bold')\n",
    "ax2.legend(fontsize=7)\n",
    "\n",
    "# --- Panel 3: FDR vs uncorrected p-values ---\n",
    "ax3 = axes[2]\n",
    "n_test = 100\n",
    "pv_sorted = np.sort(rng.uniform(0, 1, n_test))\n",
    "# Inject 10 truly small p-values\n",
    "pv_sorted[:10] = rng.uniform(0, 0.01, 10)\n",
    "pv_sorted = np.sort(pv_sorted)\n",
    "qv_sorted = np.sort(multiple_testing_correction(pv_sorted))\n",
    "\n",
    "ax3.plot(range(n_test), pv_sorted, 'o-', color='#e74c3c', ms=3, lw=1, label='Uncorrected p')\n",
    "ax3.plot(range(n_test), qv_sorted, 's-', color='#27ae60', ms=3, lw=1, label='BH q-values')\n",
    "ax3.axhline(0.05, color='orange', linestyle='--', alpha=0.7, label='0.05 threshold')\n",
    "ax3.set_xlabel('Gene rank (sorted by p-value)')\n",
    "ax3.set_ylabel('p-value / q-value')\n",
    "ax3.set_title('FDR Correction Effect', fontweight='bold')\n",
    "ax3.legend(fontsize=8)\n",
    "ax3.grid(alpha=0.3)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('stats_module_viz.png', dpi=120, bbox_inches='tight')\n",
    "plt.show()"
   ]
  },
