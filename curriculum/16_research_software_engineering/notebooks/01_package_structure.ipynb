    "import matplotlib.pyplot as plt\n",
    "import matplotlib.patches as mpatches\n",
    "from matplotlib.patches import FancyArrowPatch\n",
    "import numpy as np\n",
    "\n",
    "fig, axes = plt.subplots(1, 3, figsize=(15, 6))\n",
    "fig.suptitle('Package Structure Overview', fontsize=14, fontweight='bold')\n",
    "\n",
    "# --- Panel 1: Directory tree as text diagram ---\n",
    "ax1 = axes[0]\n",
    "ax1.set_xlim(0, 10)\n",
    "ax1.set_ylim(0, 14)\n",
    "ax1.axis('off')\n",
    "ax1.set_title('Directory Tree', fontweight='bold')\n",
    "\n",
    "tree_lines = [\n",
    "    (0.2, 13, 'utilities/', 'folder'),\n",
    "    (0.5, 12, '└── compbio_utils/', 'folder'),\n",
    "    (1.0, 11, '    ├── pyproject.toml', 'file'),\n",
    "    (1.0, 10, '    ├── src/', 'folder'),\n",
    "    (1.5, 9,  '    │   └── compbio_utils/', 'pkg'),\n",
    "    (2.0, 8,  '    │       ├── __init__.py', 'init'),\n",
    "    (2.0, 7,  '    │       ├── sequence.py', 'module'),\n",
    "    (2.0, 6,  '    │       ├── stats.py', 'module'),\n",
    "    (2.0, 5,  '    │       └── io.py', 'module'),\n",
    "    (1.0, 4,  '    └── tests/', 'folder'),\n",
    "    (1.5, 3,  '        ├── conftest.py', 'file'),\n",
    "    (1.5, 2,  '        ├── test_sequence.py', 'file'),\n",
    "    (1.5, 1,  '        └── test_stats.py', 'file'),\n",
    "]\n",
    "\n",
    "colors = {'folder': '#4a90d9', 'file': '#666', 'pkg': '#e67e22', \n",
    "          'init': '#27ae60', 'module': '#8e44ad'}\n",
    "\n",
    "for x, y, text, kind in tree_lines:\n",
    "    ax1.text(x, y, text, fontsize=8, fontfamily='monospace',\n",
    "             color=colors[kind], va='center')\n",
    "\n",
    "# Legend for panel 1\n",
    "legend_items = [\n",
    "    mpatches.Patch(color=colors['folder'], label='Directory'),\n",
    "    mpatches.Patch(color=colors['pkg'], label='Package root'),\n",
    "    mpatches.Patch(color=colors['init'], label='__init__.py'),\n",
    "    mpatches.Patch(color=colors['module'], label='Submodule'),\n",
    "]\n",
    "ax1.legend(handles=legend_items, loc='lower left', fontsize=7)\n",
    "\n",
    "# --- Panel 2: Import dependency graph ---\n",
    "ax2 = axes[1]\n",
    "ax2.set_xlim(-1.5, 1.5)\n",
    "ax2.set_ylim(-1.5, 1.5)\n",
    "ax2.axis('off')\n",
    "ax2.set_title('Import Dependency Graph', fontweight='bold')\n",
    "\n",
    "nodes = {\n",
    "    '__init__': (0, 0),\n",
    "    'sequence': (-1, -1),\n",
    "    'stats': (0, -1),\n",
    "    'io': (1, -1),\n",
    "    'numpy': (-1.2, -0.3),\n",
    "    'pandas': (1.2, -0.3),\n",
    "}\n",
    "\n",
    "node_colors = {\n",
    "    '__init__': '#27ae60', 'sequence': '#8e44ad', 'stats': '#8e44ad',\n",
    "    'io': '#8e44ad', 'numpy': '#e67e22', 'pandas': '#e67e22'\n",
    "}\n",
    "\n",
    "edges = [\n",
    "    ('__init__', 'sequence'), ('__init__', 'stats'), ('__init__', 'io'),\n",
    "    ('stats', 'numpy'), ('io', 'pandas'), ('sequence', 'numpy')\n",
    "]\n",
    "\n",
    "for src, dst in edges:\n",
    "    x0, y0 = nodes[src]\n",
    "    x1, y1 = nodes[dst]\n",
    "    ax2.annotate('', xy=(x1, y1), xytext=(x0, y0),\n",
    "                 arrowprops=dict(arrowstyle='->', color='#aaa', lw=1.5))\n",
    "\n",
    "for name, (x, y) in nodes.items():\n",
    "    circle = plt.Circle((x, y), 0.28, color=node_colors[name], zorder=3)\n",
    "    ax2.add_patch(circle)\n",
    "    ax2.text(x, y, name, ha='center', va='center', fontsize=7,\n",
    "             fontfamily='monospace', color='white', fontweight='bold', zorder=4)\n",
    "\n",
    "# --- Panel 3: Module sizes (lines of code estimate) ---\n",
    "ax3 = axes[2]\n",
    "modules = ['__init__', 'sequence', 'stats', 'io', 'tests']\n",
    "target_loc = [30, 120, 80, 100, 200]  # target lines of code\n",
    "colors_bar = ['#27ae60', '#8e44ad', '#8e44ad', '#8e44ad', '#e67e22']\n",
    "\n",
    "bars = ax3.barh(modules, target_loc, color=colors_bar, alpha=0.8)\n",
    "ax3.set_xlabel('Target lines of code')\n",
    "ax3.set_title('Module Size Targets', fontweight='bold')\n",
    "ax3.axvline(x=0, color='black', lw=0.5)\n",
    "\n",
    "for bar, val in zip(bars, target_loc):\n",
    "    ax3.text(bar.get_width() + 2, bar.get_y() + bar.get_height() / 2,\n",
    "             f'{val}', va='center', fontsize=9)\n",
    "\n",
    "ax3.set_xlim(0, 250)\n",
    "ax3.grid(axis='x', alpha=0.3)\n",
    "\n",
    "plt.tight_layout()\n",
