    "## 3. Import Mechanics — Why the `src/` Layout Matters"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Demonstrate the import resolution difference\n",
    "import sys\n",
    "\n",
    "# WITHOUT src/ layout: if you're in the project root and it contains\n",
    "# a directory named compbio_utils/, Python will import THAT directory\n",
    "# (the source), not the installed package. Tests can pass locally\n",
    "# but fail for users who installed from PyPI.\n",
    "\n",
    "# WITH src/ layout: the source is one level deeper, so Python can't\n",
    "# accidentally find it. Only the installed package (via pip install -e .)\n",
    "# is importable. This guarantees tests exercise the installed artifact.\n",
    "\n",
    "print('Import resolution order (sys.path excerpt):')\n",
    "for p in sys.path[:5]:\n",
    "    print(f'  {p}')\n",
    "print('  ...')\n",
    "\n",
    "print()\n",
    "print('Key insight: with src/ layout, the package is NOT on sys.path')\n",
    "print('until you run: pip install -e .')\n",
    "print('This is a feature, not a bug.')"
   ]
  },
  {
   "cell_type": "markdown",
