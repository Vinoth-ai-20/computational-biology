   "source": [
    "# Validate against Biopython\n",
    "from Bio import Align\n",
    "import numpy as np\n",
    "\n",
    "\n",
    "def biopython_nw_score(seq1, seq2, match=1, mismatch=-1, gap=-2):\n",
    "    aligner = Align.PairwiseAligner()\n",
    "    aligner.mode = 'global'\n",
    "    aligner.match_score = match\n",
    "    aligner.mismatch_score = mismatch\n",
    "    aligner.open_gap_score = gap\n",
    "    aligner.extend_gap_score = gap\n",
    "    return aligner.score(seq1, seq2)\n",
    "\n",
    "\n",
    "def biopython_sw_score(seq1, seq2, match=2, mismatch=-1, gap=-1):\n",
    "    aligner = Align.PairwiseAligner()\n",
    "    aligner.mode = 'local'\n",
    "    aligner.match_score = match\n",
    "    aligner.mismatch_score = mismatch\n",
    "    aligner.open_gap_score = gap\n",
    "    aligner.extend_gap_score = gap\n",
    "    return aligner.score(seq1, seq2)\n",
    "\n",
    "\n",
    "# Generate 50 test pairs\n",
    "rng = np.random.default_rng(42)\n",
    "bases = list('ACGT')\n",
    "test_pairs = []\n",
    "for _ in range(50):\n",
    "    L1 = rng.integers(5, 20)\n",
    "    L2 = rng.integers(5, 20)\n",
    "    s1 = ''.join(rng.choice(bases, L1))\n",
    "    s2 = ''.join(rng.choice(bases, L2))\n",
    "    test_pairs.append((s1, s2))\n",
    "\n",
    "# Compare NW scores\n",
    "our_nw_scores = []\n",
    "bio_nw_scores = []\n",
    "nw_matches = 0\n",
    "\n",
    "for s1, s2 in test_pairs:\n",
    "    our_score, _, _ = needleman_wunsch(s1, s2)\n",
    "    bio_score = biopython_nw_score(s1, s2)\n",
    "    our_nw_scores.append(our_score)\n",
    "    bio_nw_scores.append(bio_score)\n",
    "    if abs(our_score - bio_score) < 0.1:\n",
    "        nw_matches += 1\n",
    "\n",
    "print(f\"NW match rate: {nw_matches}/50 = {nw_matches/50*100:.1f}%\")\n",
    "print(f\"(Portfolio requirement: ≥95%, i.e. ≥47/50)\")"
   ]
  },
  {
   "cell_type": "code",
