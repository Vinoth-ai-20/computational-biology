   "metadata": {},
   "outputs": [],
   "source": [
    "# Runtime scaling: O(n²) validation\n",
    "import time\n",
    "\n",
    "lengths = [20, 50, 100, 150, 200]\n",
    "nw_times = []\n",
    "sw_times = []\n",
    "\n",
    "rng = np.random.default_rng(0)\n",
    "for L in lengths:\n",
    "    s1 = ''.join(rng.choice(list('ACGT'), L))\n",
    "    s2 = ''.join(rng.choice(list('ACGT'), L))\n",
    "\n",
    "    t0 = time.time()\n",
    "    for _ in range(5):\n",
    "        needleman_wunsch(s1, s2)\n",
    "    nw_times.append((time.time() - t0) / 5 * 1000)  # ms\n",
    "\n",
    "    t0 = time.time()\n",
    "    for _ in range(5):\n",
    "        smith_waterman(s1, s2)\n",
    "    sw_times.append((time.time() - t0) / 5 * 1000)\n",
    "\n",
    "print(\"Runtime (ms):\")\n",
    "print(f\"{'Length':>8} {'NW (ms)':>10} {'SW (ms)':>10}\")\n",
    "for L, nt, st in zip(lengths, nw_times, sw_times):\n",
    "    print(f\"{L:>8} {nt:>10.3f} {st:>10.3f}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
