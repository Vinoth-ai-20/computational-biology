    "# Mini-Project 01 — NW and SW from Scratch: Benchmark vs. Biopython\n",
    "\n",
    "**Module:** 08 — Bioinformatics: Sequence Analysis  \n",
    "**Notebook:** 16 of 18 (Portfolio artifact 1)  \n",
    "**Time estimate:** 3–4 hours  \n",
    "\n",
    "**Portfolio artifact:** `portfolio/module08_nw_sw_benchmark.png`\n",
    "\n",
    "> **Rules:** All alignment functions written from memory in this notebook.\n",
    "> No copying from NB04/NB05. Biopython used only for validation.\n",
    "> 95% of test cases must match Biopython's score."
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "## Objective\n",
    "\n",
    "Produce a 4-panel portfolio figure demonstrating:\n",
    "- Panel A: One NW alignment example (annotated)\n",
    "- Panel B: One SW alignment example (shows local vs. global difference)\n",
    "- Panel C: Score comparison across 50 test pairs (our NW vs. Biopython NW)\n",
    "- Panel D: Runtime scaling validation (O(n²) for both algorithms)\n",
    "\n",
    "This is the Pass-3 implementation for NW and SW — the implementations must be written\n",
    "from memory, not derived from this notebook's cells."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================\n",
    "# IMPLEMENT FROM MEMORY — no reference to NB04/NB05\n",
    "# ============================================================\n",
    "import numpy as np\n",
    "from typing import Tuple\n",
    "\n",
    "\n",
    "def needleman_wunsch(\n",
    "    seq1: str,\n",
    "    seq2: str,\n",
    "    match: int = 1,\n",
    "    mismatch: int = -1,\n",
    "    gap: int = -2\n",
    ") -> Tuple[int, str, str]:\n",
    "    \"\"\"\n",
    "    Global alignment (NW). Implement from scratch.\n",
    "    Returns (score, aligned_seq1, aligned_seq2).\n",
    "    \"\"\"\n",
    "    # YOUR IMPLEMENTATION\n",
    "    n, m = len(seq1), len(seq2)\n",
    "    F = np.zeros((n + 1, m + 1), dtype=int)\n",
    "\n",
    "    for i in range(n + 1): F[i, 0] = i * gap\n",
    "    for j in range(m + 1): F[0, j] = j * gap\n",
    "\n",
    "    for i in range(1, n + 1):\n",
    "        for j in range(1, m + 1):\n",
    "            sc = match if seq1[i-1] == seq2[j-1] else mismatch\n",
    "            F[i, j] = max(\n",
    "                F[i-1, j-1] + sc,\n",
    "                F[i-1, j] + gap,\n",
    "                F[i, j-1] + gap\n",
    "            )\n",
    "\n",
    "    a1, a2 = [], []\n",
    "    i, j = n, m\n",
    "    while i > 0 or j > 0:\n",
    "        if i > 0 and j > 0:\n",
    "            sc = match if seq1[i-1] == seq2[j-1] else mismatch\n",
    "            if F[i, j] == F[i-1, j-1] + sc:\n",
    "                a1.append(seq1[i-1]); a2.append(seq2[j-1]); i -= 1; j -= 1; continue\n",
    "        if i > 0 and F[i, j] == F[i-1, j] + gap:\n",
    "            a1.append(seq1[i-1]); a2.append('-'); i -= 1\n",
    "        else:\n",
    "            a1.append('-'); a2.append(seq2[j-1]); j -= 1\n",
    "\n",
    "    return int(F[n, m]), ''.join(reversed(a1)), ''.join(reversed(a2))\n",
    "\n",
    "\n",
    "def smith_waterman(\n",
    "    seq1: str,\n",
    "    seq2: str,\n",
    "    match: int = 2,\n",
    "    mismatch: int = -1,\n",
    "    gap: int = -1\n",
    ") -> Tuple[int, str, str]:\n",
    "    \"\"\"\n",
    "    Local alignment (SW). Implement from scratch.\n",
    "    Returns (score, aligned_seq1, aligned_seq2).\n",
    "    \"\"\"\n",
    "    # YOUR IMPLEMENTATION\n",
    "    n, m = len(seq1), len(seq2)\n",
    "    H = np.zeros((n + 1, m + 1), dtype=int)\n",
    "\n",
    "    for i in range(1, n + 1):\n",
    "        for j in range(1, m + 1):\n",
    "            sc = match if seq1[i-1] == seq2[j-1] else mismatch\n",
    "            H[i, j] = max(0, H[i-1,j-1]+sc, H[i-1,j]+gap, H[i,j-1]+gap)\n",
    "\n",
    "    max_score = int(H.max())\n",
    "    max_pos = np.unravel_index(H.argmax(), H.shape)\n",
    "    i, j = int(max_pos[0]), int(max_pos[1])\n",
    "\n",
    "    a1, a2 = [], []\n",
    "    while i > 0 and j > 0 and H[i, j] > 0:\n",
    "        sc = match if seq1[i-1] == seq2[j-1] else mismatch\n",
    "        if H[i, j] == H[i-1, j-1] + sc:\n",
    "            a1.append(seq1[i-1]); a2.append(seq2[j-1]); i -= 1; j -= 1\n",
    "        elif H[i, j] == H[i-1, j] + gap:\n",
    "            a1.append(seq1[i-1]); a2.append('-'); i -= 1\n",
    "        else:\n",
    "            a1.append('-'); a2.append(seq2[j-1]); j -= 1\n",
    "\n",
    "    return max_score, ''.join(reversed(a1)), ''.join(reversed(a2))\n",
    "\n",
    "\n",
    "print(\"Implementations defined. Running tests...\")\n",
    "s, a1, a2 = needleman_wunsch('ATCG', 'ATCG')\n",
    "print(f\"NW test: score={s}, aligned: {a1}/{a2}\")\n",
    "\n",
    "s, a1, a2 = smith_waterman('AAAAATCGATCG', 'ATCGATCG')\n",
    "print(f\"SW test: score={s}, aligned: {a1}/{a2}\")"
   ]
  },
