   "source": [
    "# Portfolio Figure: 4 panels\n",
    "import matplotlib.pyplot as plt\n",
    "import matplotlib.gridspec as gridspec\n",
    "import numpy as np\n",
    "\n",
    "fig = plt.figure(figsize=(14, 12))\n",
    "gs = gridspec.GridSpec(2, 2, fig, hspace=0.35, wspace=0.3)\n",
    "\n",
    "# Panel A: NW example\n",
    "ax1 = fig.add_subplot(gs[0, 0])\n",
    "ex_seq1 = 'GCATGCU'\n",
    "ex_seq2 = 'GATTACA'\n",
    "score, a1, a2 = needleman_wunsch(ex_seq1, ex_seq2)\n",
    "mid = ''.join('|' if a == b else (' ' if '-' in (a, b) else '.') for a, b in zip(a1, a2))\n",
    "\n",
    "# DP matrix\n",
    "n, m = len(ex_seq1), len(ex_seq2)\n",
    "F = np.zeros((n+1, m+1), dtype=int)\n",
    "for i in range(n+1): F[i,0] = i*(-2)\n",
    "for j in range(m+1): F[0,j] = j*(-2)\n",
    "for i in range(1,n+1):\n",
    "    for j in range(1,m+1):\n",
    "        sc = 1 if ex_seq1[i-1]==ex_seq2[j-1] else -1\n",
    "        F[i,j] = max(F[i-1,j-1]+sc, F[i-1,j]-2, F[i,j-1]-2)\n",
    "\n",
    "ax1.imshow(F, cmap='RdYlGn', aspect='auto')\n",
    "ax1.set_xticks(range(m+1))\n",
    "ax1.set_xticklabels(['-']+list(ex_seq2), fontsize=9)\n",
    "ax1.set_yticks(range(n+1))\n",
    "ax1.set_yticklabels(['-']+list(ex_seq1), fontsize=9)\n",
    "for i in range(n+1):\n",
    "    for j in range(m+1):\n",
    "        ax1.text(j, i, F[i,j], ha='center', va='center', fontsize=7)\n",
    "ax1.set_title(f'A. NW Global Alignment\\n\"{ex_seq1}\" vs \"{ex_seq2}\"\\nScore={score}', fontsize=10)\n",
    "\n",
    "# Panel B: SW vs NW comparison\n",
    "ax2 = fig.add_subplot(gs[0, 1])\n",
    "long_seq1 = 'AAAAATCGATCGTTTT'\n",
    "short_seq = 'ATCGATCG'\n",
    "\n",
    "sw_score, sw_a1, sw_a2 = smith_waterman(long_seq1, short_seq, match=2, mismatch=-1, gap=-1)\n",
    "nw_score, nw_a1, nw_a2 = needleman_wunsch(long_seq1, short_seq, match=1, mismatch=-1, gap=-2)\n",
    "\n",
    "ax2.axis('off')\n",
    "text_b = (\n",
    "    f\"B. SW (local) vs NW (global)\\n\"\n",
    "    f\"seq1: {long_seq1}\\n\"\n",
    "    f\"seq2:         {short_seq}\\n\\n\"\n",
    "    f\"SW score: {sw_score}\\n\"\n",
    "    f\"SW seq1: {sw_a1}\\n\"\n",
    "    f\"SW seq2: {sw_a2}\\n\"\n",
    "    f\"(SW finds only the matching core)\\n\\n\"\n",
    "    f\"NW score: {nw_score}\\n\"\n",
    "    f\"NW seq1: {nw_a1[:20]}...\\n\"\n",
    "    f\"NW seq2: {nw_a2[:20]}...\\n\"\n",
    "    f\"(NW forces full-length alignment)\"\n",
    ")\n",
    "ax2.text(0.02, 0.98, text_b, transform=ax2.transAxes, fontsize=9,\n",
    "         verticalalignment='top', fontfamily='monospace',\n",
    "         bbox=dict(boxstyle='round', facecolor='lightyellow', alpha=0.9))\n",
    "\n",
    "# Panel C: Score comparison scatter\n",
    "ax3 = fig.add_subplot(gs[1, 0])\n",
    "ax3.scatter(bio_nw_scores, our_nw_scores, alpha=0.5, s=20, color='steelblue')\n",
    "min_v = min(min(bio_nw_scores), min(our_nw_scores))\n",
    "max_v = max(max(bio_nw_scores), max(our_nw_scores))\n",
    "ax3.plot([min_v, max_v], [min_v, max_v], 'r--', lw=2, label='Perfect agreement')\n",
    "ax3.set_xlabel('Biopython NW score')\n",
    "ax3.set_ylabel('Our NW score')\n",
    "ax3.set_title(f'C. Score validation: Our NW vs Biopython\\n({nw_matches}/50 exact matches, {nw_matches/50*100:.0f}%)', fontsize=10)\n",
    "ax3.legend(fontsize=8)\n",
    "\n",
    "# Panel D: Runtime scaling\n",
    "ax4 = fig.add_subplot(gs[1, 1])\n",
    "L_arr = np.array(lengths)\n",
    "ax4.plot(L_arr, nw_times, 'b-o', markersize=6, label='NW')\n",
    "ax4.plot(L_arr, sw_times, 'r-s', markersize=6, label='SW')\n",
    "# Fit O(n²)\n",
    "coeffs = np.polyfit(L_arr**2, nw_times, 1)\n",
    "fit_vals = np.polyval(coeffs, L_arr**2)\n",
    "ax4.plot(L_arr, fit_vals, 'b--', alpha=0.5, label=f'O(n²) fit')\n",
    "ax4.set_xlabel('Sequence length (bp)')\n",
    "ax4.set_ylabel('Runtime (ms)')\n",
    "ax4.set_title('D. Runtime scaling validation\\nBoth algorithms are O(n²)', fontsize=10)\n",
    "ax4.legend(fontsize=8)\n",
    "\n",
    "plt.suptitle('Module 08 Portfolio: Needleman-Wunsch and Smith-Waterman\\n'\n",
    "             'From-scratch implementation validated against Biopython',\n",
    "             fontsize=12, fontweight='bold')\n",
    "\n",
    "plt.savefig('../../portfolio/module08_nw_sw_benchmark.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "print(\"Portfolio figure saved to portfolio/module08_nw_sw_benchmark.png\")"
   ]
