    "# Validate against scipy (UPGMA comparison)\n",
    "import matplotlib.pyplot as plt\n",
    "from scipy.cluster.hierarchy import linkage, dendrogram\n",
    "from scipy.spatial.distance import squareform\n",
    "\n",
    "# Compare UPGMA vs NJ on a non-clock distance matrix\n",
    "# Non-clock: lineage A evolves faster\n",
    "names_test = ['A', 'B', 'C', 'D']\n",
    "# True tree: ((A,B),(C,D)); A's branch is 3x longer\n",
    "# So A-B = 1+3=4; A-C = 3+2+2=7; A-D = 3+2+2=7\n",
    "# B-C = 1+2+2=5; B-D = 1+2+2=5; C-D = 2+2=4\n",
    "D_nonclock = np.array([\n",
    "    [0, 4, 7, 7],\n",
    "    [4, 0, 5, 5],\n",
    "    [7, 5, 0, 4],\n",
    "    [7, 5, 4, 0],\n",
    "], dtype=float)\n",
    "\n",
    "fig, axes = plt.subplots(1, 2, figsize=(12, 5))\n",
    "\n",
    "# UPGMA dendrogram\n",
    "ax1 = axes[0]\n",
    "condensed = squareform(D_nonclock)\n",
    "Z_upgma = linkage(condensed, method='average')\n",
    "dendrogram(Z_upgma, labels=names_test, ax=ax1, color_threshold=4)\n",
    "ax1.set_title('UPGMA tree\\n(May group A incorrectly due to long branch)')\n",
    "ax1.set_ylabel('Distance')\n",
    "\n",
    "# NJ result\n",
    "ax2 = axes[1]\n",
    "tree_nj_test = neighbour_joining(D_nonclock, names_test)\n",
    "nw = tree_nj_test.to_newick()\n",
    "\n",
    "# Simple text display of NJ result\n",
    "ax2.axis('off')\n",
    "ax2.text(0.05, 0.95, f'NJ tree (Newick):\\n\\n{nw}\\n\\nExpected: ((A,B),(C,D))\\n\\n'\n",
    "         'NJ correctly identifies the (A,B) and (C,D) clades\\neven though A has a long branch.',\n",
    "         transform=ax2.transAxes, fontsize=11, verticalalignment='top',\n",
    "         fontfamily='monospace',\n",
    "         bbox=dict(boxstyle='round', facecolor='lightyellow', alpha=0.8))\n",
    "ax2.set_title('NJ result (corrects for rate variation)')\n",
    "\n",
    "plt.suptitle('UPGMA vs NJ on non-clock data\\n(A evolves faster than B, C, D)', fontsize=11)\n",
    "plt.tight_layout()\n",
    "plt.savefig('nj_vs_upgma.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()"
   ]
