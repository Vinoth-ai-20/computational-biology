    "# Effect of k on assembly (k too small → too many paths; k too large → gaps)\n",
    "rng = np.random.default_rng(42)\n",
    "# Include a repeat region\n",
    "true_seq = 'ATCGATCG' + 'AAAA' + 'ATCGATCG'  # 'ATCGATCG' appears twice\n",
    "reads_all = [true_seq[i:i+8] for i in range(0, len(true_seq)-7, 2)]\n",
    "\n",
    "print(f\"True sequence: {true_seq} (length {len(true_seq)})\")\n",
    "print(f\"Contains repeat: 'ATCGATCG' appears at positions 0 and 12\\n\")\n",
    "\n",
    "for k in [3, 5, 8]:\n",
    "    graph = build_debruijn(reads_all, k)\n",
    "    n_nodes = len(graph)\n",
    "    n_edges = sum(len(v) for v in graph.values())\n",
    "    path = find_eulerian_path(graph)\n",
    "    if path:\n",
    "        assembled = path_to_sequence(path)\n",
    "        print(f\"k={k}: nodes={n_nodes}, edges={n_edges}, assembled_len={len(assembled)}\")\n",
    "        print(f\"  Assembled: {assembled[:40]}{'...' if len(assembled)>40 else ''}\")\n",
    "        print(f\"  Correct:   {assembled == true_seq}\")\n",
    "    else:\n",
    "        print(f\"k={k}: no Eulerian path found\")"
