    "# Step 7 — Visualization: De Bruijn graph\n",
    "import matplotlib.pyplot as plt\n",
    "import matplotlib.patches as mpatches\n",
    "from matplotlib.patches import FancyArrowPatch\n",
    "import numpy as np\n",
    "\n",
    "\n",
    "def plot_debruijn_simple():\n",
    "    # Small example: sequence = 'ATCGATCG', k=3\n",
    "    seq = 'ATCGATCG'\n",
    "    k = 3\n",
    "    kmers = extract_kmers(seq, k)\n",
    "    edges = [(km[:-1], km[1:], km) for km in kmers]\n",
    "    nodes = sorted(set([e[0] for e in edges] + [e[1] for e in edges]))\n",
    "\n",
    "    n = len(nodes)\n",
    "    angles = np.linspace(0, 2*np.pi, n, endpoint=False)\n",
    "    pos = {node: (np.cos(a), np.sin(a)) for node, a in zip(nodes, angles)}\n",
    "\n",
    "    fig, axes = plt.subplots(1, 2, figsize=(14, 6))\n",
    "\n",
    "    # Panel A: De Bruijn graph\n",
    "    ax = axes[0]\n",
    "    for node, (x, y) in pos.items():\n",
    "        ax.plot(x, y, 'o', ms=30, color='steelblue', zorder=3)\n",
    "        ax.text(x, y, node, ha='center', va='center', fontsize=9, color='white', zorder=4)\n",
    "\n",
    "    for u, v, label in edges:\n",
    "        xu, yu = pos[u]\n",
    "        xv, yv = pos[v]\n",
    "        # Slightly offset for clarity\n",
    "        mid_x = (xu + xv) / 2\n",
    "        mid_y = (yu + yv) / 2\n",
    "        ax.annotate('', xy=(xv, yv), xytext=(xu, yu),\n",
    "                    arrowprops=dict(arrowstyle='->', color='red', lw=1.5,\n",
    "                                    connectionstyle='arc3,rad=0.15'))\n",
    "        ax.text(mid_x*1.15, mid_y*1.15, label, fontsize=8, color='red',\n",
    "                ha='center', va='center',\n",
    "                bbox=dict(boxstyle='round,pad=0.2', facecolor='white', alpha=0.7))\n",
    "\n",
    "    ax.set_xlim(-1.6, 1.6)\n",
    "    ax.set_ylim(-1.6, 1.6)\n",
    "    ax.axis('off')\n",
    "    ax.set_title(f'De Bruijn Graph for \"{seq}\" (k={k})\\nNodes=(k-1)-mers, Edges=k-mers', fontsize=10)\n",
    "\n",
    "    # Panel B: Explain the concept\n",
    "    ax2 = axes[1]\n",
    "    ax2.axis('off')\n",
    "    explanation = (\n",
    "        f\"Sequence: {seq}\\n\"\n",
    "        f\"k = {k}\\n\\n\"\n",
    "        f\"k-mers (edges):\\n\" +\n",
    "        ''.join(f\"  {km}: {km[:-1]} → {km[1:]}\\n\" for km in kmers) +\n",
    "        f\"\\nAssembly = Eulerian path\\n\"\n",
    "        f\"(traverse each edge once)\\n\\n\"\n",
    "        f\"Path: AT → TC → CG → GA → AT → TC → CG\\n\\n\"\n",
    "        f\"Reconstruct:\\n\"\n",
    "        f\"AT + C + G + A + T + C + G = ATCGATCG\\n\\n\"\n",
    "        f\"Key: Eulerian path = polynomial O(E)\\n\"\n",
    "        f\"vs. Hamiltonian path = NP-hard\"\n",
    "    )\n",
    "    ax2.text(0.05, 0.95, explanation, transform=ax2.transAxes, fontsize=10,\n",
    "             verticalalignment='top', fontfamily='monospace',\n",
    "             bbox=dict(boxstyle='round', facecolor='lightyellow', alpha=0.8))\n",
    "    ax2.set_title('How De Bruijn assembly works', fontsize=10)\n",
    "\n",
    "    plt.tight_layout()\n",
    "    plt.savefig('debruijn_graph.png', dpi=150, bbox_inches='tight')\n",
    "    plt.show()\n",
    "\n",
    "\n",
    "plot_debruijn_simple()"
   ]
