    "# Practice: read trees in Newick format using ETE3 or Biopython\n",
    "from Bio import Phylo\n",
    "from io import StringIO\n",
    "\n",
    "# Newick format: the standard for tree storage\n",
    "newick_str = \"((Human:0.012, Chimp:0.013):0.018, (Gorilla:0.025, (Orang:0.05, Gibbon:0.08):0.01):0.02, Mouse:0.15);\"\n",
    "\n",
    "tree = Phylo.read(StringIO(newick_str), 'newick')\n",
    "\n",
    "print(\"Tree in ASCII format:\")\n",
    "Phylo.draw_ascii(tree)\n",
    "\n",
    "print(f\"\\nNumber of leaves: {len(tree.get_terminals())}\")\n",
    "print(f\"Number of internal nodes: {len(tree.get_nonterminals())}\")\n",
    "print(f\"Total branch length: {tree.total_branch_length():.4f}\")\n",
    "\n",
    "# Check if human and chimp are sisters\n",
    "human = tree.find_any('Human')\n",
    "chimp = tree.find_any('Chimp')\n",
    "mrca_hc = tree.common_ancestor('Human', 'Chimp')\n",
    "mrca_hg = tree.common_ancestor('Human', 'Gorilla')\n",
    "\n",
    "print(f\"\\nHuman-Chimp MRCA depth: {tree.distance(mrca_hc):.4f}\")\n",
    "print(f\"Human-Gorilla MRCA depth: {tree.distance(mrca_hg):.4f}\")\n",
    "print(\"Human and Chimp are sisters:\",\n",
    "      tree.distance(mrca_hc) > tree.distance(mrca_hg))"
   ]
  },
