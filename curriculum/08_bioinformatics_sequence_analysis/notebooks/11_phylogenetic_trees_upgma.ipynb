    "# Step 7 — Visualization: dendrogram\n",
    "import matplotlib.pyplot as plt\n",
    "from scipy.cluster.hierarchy import linkage, dendrogram\n",
    "from scipy.spatial.distance import squareform\n",
    "\n",
    "\n",
    "def plot_upgma_dendrogram(D: np.ndarray, names: list[str], title: str = 'UPGMA dendrogram'):\n",
    "    condensed = squareform(D)\n",
    "    Z = linkage(condensed, method='average')  # average linkage = UPGMA\n",
    "\n",
    "    fig, ax = plt.subplots(figsize=(8, 5))\n",
    "    dendrogram(Z, labels=names, ax=ax, orientation='right',\n",
    "               color_threshold=0.5 * D.max())\n",
    "    ax.set_xlabel('Distance')\n",
    "    ax.set_title(title)\n",
    "    plt.tight_layout()\n",
    "    return fig\n",
    "\n",
    "\n",
    "# Primate example (simplified distances)\n",
    "primates = ['Human', 'Chimp', 'Gorilla', 'Orang', 'Gibbon', 'Mouse']\n",
    "# Fictional but structured distances\n",
    "D_primates = np.array([\n",
    "    [0,   1.2, 1.8, 3.0, 4.0, 7.0],\n",
    "    [1.2, 0,   1.6, 3.0, 4.0, 7.0],\n",
    "    [1.8, 1.6, 0,   3.2, 4.1, 7.1],\n",
    "    [3.0, 3.0, 3.2, 0,   4.5, 7.5],\n",
    "    [4.0, 4.0, 4.1, 4.5, 0,   8.0],\n",
    "    [7.0, 7.0, 7.1, 7.5, 8.0, 0  ],\n",
    "], dtype=float)\n",
    "\n",
    "fig = plot_upgma_dendrogram(D_primates, primates, 'UPGMA tree of primates (simplified)')\n",
    "plt.savefig('upgma_tree.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "\n",
    "# Also run our implementation\n",
    "tree_primates = upgma(D_primates, primates)\n",
    "print(f\"Newick: {tree_primates.to_newick()}\")"
   ]
