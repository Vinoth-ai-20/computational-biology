    "# Step 5 — Portfolio figure (4 panels)\n",
    "import matplotlib.pyplot as plt\n",
    "import matplotlib.gridspec as gridspec\n",
    "from Bio import Phylo\n",
    "from io import StringIO\n",
    "\n",
    "os.makedirs('../../portfolio/module08_phylogenetics_pipeline', exist_ok=True)\n",
    "\n",
    "fig = plt.figure(figsize=(14, 12))\n",
    "gs = gridspec.GridSpec(2, 2, fig, hspace=0.4, wspace=0.35)\n",
    "\n",
    "# Panel A: Distance matrix heatmap\n",
    "ax1 = fig.add_subplot(gs[0, 0])\n",
    "im = ax1.imshow(D[:n, :n], cmap='YlOrRd', aspect='auto', vmin=0)\n",
    "ax1.set_xticks(range(n))\n",
    "ax1.set_xticklabels(species_names, rotation=30, ha='right', fontsize=9)\n",
    "ax1.set_yticks(range(n))\n",
    "ax1.set_yticklabels(species_names, fontsize=9)\n",
    "for i in range(n):\n",
    "    for j in range(n):\n",
    "        ax1.text(j, i, f'{D[i,j]:.3f}', ha='center', va='center', fontsize=8)\n",
    "ax1.set_title('A. JC69 Distance Matrix\\n(from MAFFT alignment)', fontsize=10)\n",
    "plt.colorbar(im, ax=ax1, fraction=0.046)\n",
    "\n",
    "# Panel B: MSA conservation plot\n",
    "ax2 = fig.add_subplot(gs[0, 1])\n",
    "seqs_list = [aligned_seqs[sp] for sp in species_names]\n",
    "ncols = len(seqs_list[0]) if seqs_list else 0\n",
    "if ncols > 0:\n",
    "    conservation = []\n",
    "    for c in range(ncols):\n",
    "        col = [s[c] for s in seqs_list]\n",
    "        from collections import Counter\n",
    "        counts = Counter(b for b in col if b != '-')\n",
    "        if not counts:\n",
    "            conservation.append(0)\n",
    "            continue\n",
    "        tot = sum(counts.values())\n",
    "        h = -sum((v/tot)*math.log2(v/tot) for v in counts.values() if v > 0)\n",
    "        max_h = math.log2(4)  # DNA: 4 possible bases\n",
    "        conservation.append(1 - h/max_h)\n",
    "\n",
    "    ax2.fill_between(range(ncols), conservation, alpha=0.7,\n",
    "                     color=['green' if c > 0.9 else 'orange' if c > 0.7 else 'red'\n",
    "                            for c in conservation])\n",
    "    ax2.set_xlabel('Alignment position')\n",
    "    ax2.set_ylabel('Conservation (1=conserved)')\n",
    "    ax2.set_title('B. MSA Column Conservation\\n(green=conserved, red=variable)', fontsize=10)\n",
    "\n",
    "# Panel C: NJ tree\n",
    "ax3 = fig.add_subplot(gs[1, 0])\n",
    "try:\n",
    "    tree = Phylo.read(StringIO(newick), 'newick')\n",
    "    Phylo.draw(tree, axes=ax3, do_show=False)\n",
    "    ax3.set_title('C. NJ Tree (from-scratch implementation)\\nBeta-globin gene family', fontsize=10)\n",
    "except Exception as e:\n",
    "    ax3.text(0.5, 0.5, f'Tree: {newick[:80]}...', transform=ax3.transAxes, ha='center')\n",
    "    ax3.set_title('C. NJ Tree (Newick)', fontsize=10)\n",
    "\n",
    "# Panel D: Pipeline summary\n",
    "ax4 = fig.add_subplot(gs[1, 1])\n",
    "ax4.axis('off')\n",
    "summary = (\n",
    "    \"D. Pipeline Summary\\n\\n\"\n",
    "    \"1. Sequences fetched from NCBI Entrez\\n\"\n",
    "    \"   (Biopython Bio.Entrez)\\n\\n\"\n",
    "    \"2. Aligned with MAFFT --auto\\n\"\n",
    "    \"   (exact command documented)\\n\\n\"\n",
    "    \"3. JC69 distance matrix computed\\n\"\n",
    "    \"   (from scratch, no scipy)\\n\\n\"\n",
    "    \"4. NJ tree built from scratch\\n\"\n",
    "    \"   (Hierholzer + Q-matrix)\\n\\n\"\n",
    "    f\"Species: {', '.join(species_names)}\\n\"\n",
    "    f\"Alignment length: {ncols} bp\\n\"\n",
    "    f\"Expected: (Human,Chimp,Gorilla) outgroup Mouse\"\n",
    ")\n",
    "ax4.text(0.05, 0.95, summary, transform=ax4.transAxes, fontsize=9,\n",
    "         verticalalignment='top',\n",
    "         bbox=dict(boxstyle='round', facecolor='lightcyan', alpha=0.8))\n",
    "\n",
    "plt.suptitle('Module 08 Portfolio: Beta-Globin Phylogenetics Pipeline\\n'\n",
    "             'NCBI → MAFFT → JC69 distances → NJ tree (all from scratch)',\n",
    "             fontsize=11, fontweight='bold')\n",
    "\n",
    "fig_path = '../../portfolio/module08_phylogenetics_pipeline/figure.png'\n",
    "plt.savefig(fig_path, dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "print(f\"Portfolio figure saved to {fig_path}\")"
   ]
