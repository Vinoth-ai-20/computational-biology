# =============================================================================
# Computational Biology — .gitignore
# Python + Jupyter + VS Code + Scientific Computing + Rust + OS
# =============================================================================

# =============================================================================
# Python
# =============================================================================

__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
cover/

# Type checkers
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
pyrightconfig.json
.ruff_cache/

# Virtual environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/
.conda/
.python-version

# =============================================================================
# Jupyter
# =============================================================================

.ipynb_checkpoints/
*/.ipynb_checkpoints/

# papermill execution outputs
*_executed.ipynb
papermill_outputs/

# =============================================================================
# VS Code
# =============================================================================

.vscode/
# Keep shared workspace settings
!.vscode/settings.json
!.vscode/extensions.json
*.code-workspace
.history/

# =============================================================================
# JetBrains / PyCharm
# =============================================================================

.idea/
*.iml
*.iws
*.ipr
out/

# =============================================================================
# Windows
# =============================================================================

Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# =============================================================================
# macOS
# =============================================================================

.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# =============================================================================
# Linux
# =============================================================================

*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# =============================================================================
# Rust
# =============================================================================

target/
**/*.rs.bk
*.pdb
# Keep Cargo.lock for application crates; library crates should not commit it
# Cargo.lock

# =============================================================================
# Scientific computing — large generated outputs
# =============================================================================

# NumPy / SciPy binary arrays
*.npy
*.npz

# HDF5 / Anndata
*.h5
*.hdf5
*.h5ad

# Pickle / joblib
*.pkl
*.pickle
*.joblib

# Parquet
*.parquet

# =============================================================================
# Bioinformatics — large, regenerable files
# =============================================================================

*.bam
*.bai
*.sam
*.vcf
*.bcf
*.bcf.gz
*.vcf.gz
*.fastq
*.fastq.gz
*.fq
*.fq.gz
*.fa.gz
*.fasta.gz

# =============================================================================
# Machine learning — model weights and run artifacts
# =============================================================================

*.pt
*.pth
*.ckpt
checkpoint_*/
runs/
wandb/
mlruns/
lightning_logs/

# =============================================================================
# Dataset cache — raw data fetched by scripts, not committed
# Raw data goes in datasets/raw/ (gitignored) — fetch via scripts/
# Processed data in datasets/processed/ IS committed if it is small and derived
# =============================================================================

curriculum/*/datasets/raw/
curriculum/*/datasets/cache/
data/raw/
data/cache/
.cache/
*.cache

# =============================================================================
# Documentation builds
# =============================================================================

docs/_build/
docs/site/
site/
_site/
.sphinx/

# =============================================================================
# Temporary files
# =============================================================================

*.tmp
*.temp
*.bak
*.swp
*.swo
*~
.tmp/
tmp/
temp/
logs/
*.log

# =============================================================================
# Secrets and credentials — never commit these
# =============================================================================

.env
.env.*
!.env.example
secrets.json
credentials.json
*.pem
*.key
*.crt
api_keys.txt

# =============================================================================
# Keep important repository files
# =============================================================================

!.gitignore
!README.md
!LICENSE
!CLAUDE.md
!Learning_Progress.md
!ENVIRONMENT.md
!requirements.txt
!environment.yml
!pyproject.toml
!.pre-commit-config.yaml
